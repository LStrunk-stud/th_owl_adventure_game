  m_Script: {fileID: 11500000, guid: b577ddb795ab10f44b8b39f5a07fafc3, type: 3}
  m_Name: Dialogue_Prof_WasBrauche
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 8b70f07df4a4ed648b07b7971cfbf521, type: 2}
    text: 'Erstens: den Bauplan. Den bekommst du in der Bibliothek. Such im Regal
      nach unserem Projekt.'
  - speaker: {fileID: 11400000, guid: 8b70f07df4a4ed648b07b7971cfbf521, type: 2}
    text: "Zweitens: das Holzgeh\xE4use. Das Holzlabor ist im Erdgeschoss."
  - speaker: {fileID: 11400000, guid: 8b70f07df4a4ed648b07b7971cfbf521, type: 2}
    text: 'Drittens: die Platine. FB5-Labor, zweiter Stock. Frag dort nach dem Studenten
      der an unserem Projekt arbeitet.'
  options: []
  repeatingDialogue: {fileID: 0}
