  m_Script: {fileID: 11500000, guid: b577ddb795ab10f44b8b39f5a07fafc3, type: 3}
  m_Name: Dialogue_Prof_Greeting
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 8b70f07df4a4ed648b07b7971cfbf521, type: 2}
    text: Ah, da bist du ja. Ich warte schon.
  - speaker: {fileID: 11400000, guid: 8b70f07df4a4ed648b07b7971cfbf521, type: 2}
    text: "Du wei\xDFt was heute ansteht: die Abgabe."
  - speaker: {fileID: 11400000, guid: 8b70f07df4a4ed648b07b7971cfbf521, type: 2}
    text: "Ich brauche drei Dinge von dir: den Bauplan aus der Bibliothek, das Holzgeh\xE4use
      aus dem Labor und die best\xFCckte Platine aus dem FB5."
  - speaker: {fileID: 11400000, guid: 8b70f07df4a4ed648b07b7971cfbf521, type: 2}
    text: "Wenn du alles hast, komm zur\xFCck. Dann schauen wir was dein Team geleistet
      hat."
  options: []
  repeatingDialogue: {fileID: 0}
