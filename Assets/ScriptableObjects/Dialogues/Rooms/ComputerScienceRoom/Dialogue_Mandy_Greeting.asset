  m_Script: {fileID: 11500000, guid: b577ddb795ab10f44b8b39f5a07fafc3, type: 3}
  m_Name: Dialogue_Mandy_Greeting
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: ea60ce53b875d43489bfce23d4dd288b, type: 2}
    text: Oh, du bist vom Arcade-Projekt richtig?
  - speaker: {fileID: 11400000, guid: ea60ce53b875d43489bfce23d4dd288b, type: 2}
    text: Ich warte schon auf euch. Die Platine ist fast fertig, ich brauch nur noch
      ein paar Sachen von dir.
  - speaker: {fileID: 11400000, guid: ea60ce53b875d43489bfce23d4dd288b, type: 2}
    text: "Erstens den USB-Stick mit den Projektdaten. Zweitens einen funktionierenden
      Taschenrechner, meiner l\xE4uft nicht mehr."
  options: []
  repeatingDialogue: {fileID: 0}
