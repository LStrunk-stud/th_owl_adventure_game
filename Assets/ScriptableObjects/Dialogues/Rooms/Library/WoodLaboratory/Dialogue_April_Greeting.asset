  m_Script: {fileID: 11500000, guid: b577ddb795ab10f44b8b39f5a07fafc3, type: 3}
  m_Name: Dialogue_April_Greeting
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: d599a38c019fd2e43b54915bd7397380, type: 2}
    text: Hey! Du bist vom Arcade-Projekt, oder?
  - speaker: {fileID: 11400000, guid: d599a38c019fd2e43b54915bd7397380, type: 2}
    text: "Ich w\xFCrde dir gerne helfen, aber ich find meine Schutzbrille nicht."
  - speaker: {fileID: 11400000, guid: d599a38c019fd2e43b54915bd7397380, type: 2}
    text: Ohne Brille darf ich hier nicht arbeiten. Das ist Vorschrift.
  options: []
  repeatingDialogue: {fileID: 0}
