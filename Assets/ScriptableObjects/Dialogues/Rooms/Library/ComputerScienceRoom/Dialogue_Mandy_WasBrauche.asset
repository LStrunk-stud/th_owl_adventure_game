  m_Script: {fileID: 11500000, guid: b577ddb795ab10f44b8b39f5a07fafc3, type: 3}
  m_Name: Dialogue_Mandy_WasBrauche
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: ea60ce53b875d43489bfce23d4dd288b, type: 2}
    text: Den USB-Stick, da sind die Schaltplan-Dateien drauf die ich brauche
  - speaker: {fileID: 11400000, guid: ea60ce53b875d43489bfce23d4dd288b, type: 2}
    text: "Und einen Taschenrechner mit Batterien. Klingt simpel, ich wei\xDF."
  - speaker: {fileID: 11400000, guid: ea60ce53b875d43489bfce23d4dd288b, type: 2}
    text: "Wenn du beides hast bin ich in f\xFCnf Minuten fertig."
  options: []
  repeatingDialogue: {fileID: 0}
